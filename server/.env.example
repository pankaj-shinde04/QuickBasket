NODE_ENV=development
PORT=5000

# MongoDB Atlas (replace <db_password> with your Atlas user password)
MONGODB_URI=mongodb+srv://pankajshinde2434_db_user:<db_password>@cluster0.gdk9m4e.mongodb.net/quickbasket?appName=Cluster0

# Auth
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# CORS — Vite dev server
CLIENT_URL=http://localhost:5173

# File uploads
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=uploads

# Resend email (optional — app runs without it)
RESEND_API_KEY=
EMAIL_FROM=QuickBasket <onboarding@resend.dev>

# Cloudinary (optional for logo upload — set cloud name from your dashboard)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
